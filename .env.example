NUXT_AZURE_SPEECH_KEY=
NUXT_AZURE_SPEECH_REGION=
NUXT_ANTHROPIC_API_KEY=  # Anthropic Claude API key for the AI pronunciation coach

# Feature stage gate: 'development' (default) or 'production'
# Pages marked with middleware: 'stage' are accessible in development only.
# Set to 'production' in your hosting environment to hide unfinished features.
NUXT_PUBLIC_APP_STAGE=development

# Supabase — @nuxtjs/supabase reads these directly (no NUXT_ prefix)
SUPABASE_URL=
SUPABASE_KEY=          # anon/public key
NUXT_SUPABASE_SECRET_KEY=  # service role key (server-only)

# SMTP for outbound auth emails (password reset, email confirmation)
# Local dev: leave blank — Supabase CLI's Inbucket captures emails at http://127.0.0.1:54324
# Hosted: configure in Supabase Dashboard → Project Settings → Auth → SMTP Settings instead
SMTP_PASSWORD=
